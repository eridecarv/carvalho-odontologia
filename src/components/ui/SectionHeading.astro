---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  align?: "left" | "center";
  titleWidth?: string;
  textWidth?: string;
  class?: string;
}

const {
  eyebrow,
  title,
  text,
  align = "left",
  titleWidth = "16ch",
  textWidth = "62ch",
  class: className = "",
} = Astro.props;

const classes = [
  "section-heading",
  `section-heading--${align}`,
  className,
]
  .filter(Boolean)
  .join(" ");
---

<div
  class={classes}
  style={`--section-heading-title-width: ${titleWidth}; --section-heading-text-width: ${textWidth};`}
>
  {eyebrow && <span class="section-heading__eyebrow">{eyebrow}</span>}

  <h2 class="section-heading__title">{title}</h2>

  {text && <p class="section-heading__text">{text}</p>}
</div>

<style>
  .section-heading {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 40px;
  }

  .section-heading--center {
    align-items: center;
    text-align: center;
  }

  .section-heading--left {
    align-items: flex-start;
    text-align: left;
  }

  .section-heading__eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .section-heading__title {
    margin: 0;
    max-width: var(--section-heading-title-width);
    font-size: clamp(2rem, 3.8vw, 3.4rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
    font-weight: 800;
    color: var(--color-text);
  }

  .section-heading__text {
    margin: 0;
    max-width: var(--section-heading-text-width);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-soft);
  }

  .section-heading--center .section-heading__title,
  .section-heading--center .section-heading__text {
    margin-inline: auto;
  }

  @media (max-width: 640px) {
    .section-heading {
      gap: 10px;
      margin-bottom: 28px;
    }

    .section-heading__eyebrow {
      font-size: 0.74rem;
      letter-spacing: 0.12em;
    }

    .section-heading__title {
      max-width: 100%;
      font-size: clamp(1.7rem, 7vw, 2.35rem);
      line-height: 1.02;
    }

    .section-heading__text {
      font-size: 0.96rem;
      line-height: 1.68;
    }
  }
</style>