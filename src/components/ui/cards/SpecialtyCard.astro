---
interface Props {
  title: string;
  text: string;
  href?: string;
}

const { title, text, href } = Astro.props;
---

<article class="specialty-card">
  <h3 class="specialty-card__title">
    {href ? <a href={href}>{title}</a> : title}
  </h3>

  <p class="specialty-card__text">{text}</p>
</article>

<style>
  .specialty-card {
    min-width: 0;
    padding: 28px 24px;
    background: #ffffff;
    border: 1px solid rgba(109, 42, 45, 0.08);
    border-radius: 18px;
    box-shadow: 0 10px 30px rgba(31, 26, 25, 0.04);
  }

  .specialty-card__title {
    margin: 0 0 10px;
    font-size: 1.06rem;
    line-height: 1.3;
    font-weight: 700;
    color: #6d2a2d;
  }

  .specialty-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .specialty-card__title a:hover {
    opacity: 0.8;
  }

  .specialty-card__text {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.68;
    color: #5b504d;
  }

  @media (max-width: 640px) {
    .specialty-card {
      padding: 22px 20px;
      border-radius: 16px;
    }

    .specialty-card__title {
      font-size: 1rem;
      margin-bottom: 8px;
    }

    .specialty-card__text {
      font-size: 0.95rem;
      line-height: 1.62;
    }
  }
</style>