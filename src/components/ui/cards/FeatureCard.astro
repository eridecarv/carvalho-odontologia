---
interface Props {
  title: string;
  text: string;
  class?: string;
}

const { title, text, class: className = "" } = Astro.props;
---

<article class={`feature-card ${className}`}>
  <h3 class="feature-card__title">{title}</h3>
  <p class="feature-card__text">{text}</p>
</article>

<style>
  .feature-card {
    min-width: 0;
    padding: 28px 24px;
    background: #ffffff;
    border: 1px solid rgba(109, 42, 45, 0.08);
    border-radius: 18px;
    box-shadow: 0 10px 30px rgba(31, 26, 25, 0.04);
  }

  .feature-card__title {
    margin: 0 0 10px;
    font-size: 1.08rem;
    line-height: 1.3;
    font-weight: 700;
    color: #6d2a2d;
  }

  .feature-card__text {
    margin: 0;
    font-size: 0.97rem;
    line-height: 1.7;
    color: #5b504d;
  }

  @media (max-width: 640px) {
    .feature-card {
      padding: 22px 20px;
      border-radius: 16px;
    }

    .feature-card__text {
      font-size: 0.96rem;
      line-height: 1.65;
    }
  }
</style>