---
interface Props {
  quote: string;
  name: string;
  meta?: string;
  class?: string;
}

const {
  quote,
  name,
  meta,
  class: className = "",
} = Astro.props;
---

<article class={`testimonial-card ${className}`}>
  <p class="testimonial-card__quote">
    “{quote}”
  </p>

  <footer class="testimonial-card__footer">
    <strong class="testimonial-card__name">{name}</strong>

    {meta && <span class="testimonial-card__meta">{meta}</span>}
  </footer>
</article>

<style>
  .testimonial-card {
    min-width: 0;
    height: 100%;
    padding: 28px 24px;
    background: #ffffff;
    border: 1px solid rgba(109, 42, 45, 0.08);
    border-radius: 18px;
    box-shadow: 0 10px 30px rgba(31, 26, 25, 0.04);
  }

  .testimonial-card__quote {
    margin: 0 0 18px;
    font-size: 0.98rem;
    line-height: 1.75;
    color: #3f3432;
  }

  .testimonial-card__footer {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .testimonial-card__name {
    font-size: 0.96rem;
    line-height: 1.3;
    color: #6d2a2d;
    font-weight: 700;
  }

  .testimonial-card__meta {
    font-size: 0.88rem;
    line-height: 1.4;
    color: #7a6d69;
  }

  @media (max-width: 640px) {
    .testimonial-card {
      padding: 22px 20px;
      border-radius: 16px;
    }

    .testimonial-card__quote {
      font-size: 0.95rem;
      line-height: 1.68;
      margin-bottom: 16px;
    }
  }
</style>