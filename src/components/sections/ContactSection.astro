---
import SectionHeading from "../ui/SectionHeading.astro";
import Button from "../ui/Button.astro";

interface ContactInfoItem {
  label: string;
  value: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  infoItems?: ContactInfoItem[];
  mapsHref?: string;
  whatsappHref?: string;
  embedSrc?: string;
}

const defaultInfoItems: ContactInfoItem[] = [
  {
    label: "Endereço",
    value: "R. Salvador Leite Marques, 420 - SL 05 - Éden, Sorocaba - SP, 18103-050",
  },
  {
    label: "Horário",
    value: "Segunda a sexta, das 9h às 18h30, e sábado até 12h",
  },
  {
    label: "Atendimento",
    value:
      "Contato direto pelo WhatsApp para dúvidas, agendamentos e confirmação de convênios disponíveis. Atendimento somente com hora marcada.",
  },
];

const {
  eyebrow = "Contato",
  title = "Entre em contato e agende seu atendimento",
  description = "Se você quer tirar dúvidas, entender possibilidades de tratamento ou consultar disponibilidade, entre em contato com a clínica. O atendimento é realizado com hora marcada.",
  infoItems = defaultInfoItems,
  mapsHref = "https://maps.app.goo.gl/iSrf1LsjAH3wTQHW8",
  whatsappHref = "https://wa.me/5515981708003",
  embedSrc = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3866.080919634617!2d-47.419833424674216!3d-23.420841578896567!2m3!1f0!2f0!3f0!2m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94cf5f59b9db8e17%3A0x11f7619e39acd01c!2sDr%20Lucas%20Carvalho%20-%20Odontologia!5e1!3m2!1spt-BR!2sbr!4v1774037223828!5m2!1spt-BR!2sbr"
,
} = Astro.props;
---
 
<section class="contact-section" id="contato">
  <div class="container">
    <div class="contact-section__grid">
      <div class="contact-section__content">
        <SectionHeading
          eyebrow={eyebrow}
          title={title}
          align="left"
        />

        <div class="contact-section__info">
          {
            infoItems.map((item) => (
              <p>
                <strong>{item.label}</strong><br />
                {item.value}
              </p>
            ))
          }
        </div>
      </div>

      <div class="contact-section__side">
        <div class="contact-section__map">
          <iframe
            src={embedSrc}
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Localização da Carvalho Odontologia no Google Maps"
          ></iframe>
        </div>

        <div class="contact-section__actions">
          <Button
            href={mapsHref}
            target="_blank"
            rel="noopener noreferrer"
            variant="secondary"
            fullWidth
          >
            Ver no Google Maps
          </Button>

          <Button
            href={whatsappHref}
            target="_blank"
            rel="noopener noreferrer"
            variant="primary"
            fullWidth
          >
            Agendar pelo WhatsApp
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding: 72px 0 88px;
    background: #f6f1eb;
  }

  .contact-section__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 460px);
    gap: 32px;
    align-items: center;
  }

  .contact-section__content,
  .contact-section__side,
  .contact-section__map,
  .contact-section__info {
    min-width: 0;
    max-width: 100%;
  }

  .contact-section__content {
    max-width: 620px;
  }

  .contact-section__info {
    display: grid;
    gap: 18px;
  }

  .contact-section__info p {
    margin: 0;
    line-height: 1.7;
    color: var(--color-text-soft);
    overflow-wrap: break-word;
  }

  .contact-section__info strong {
    display: inline-block;
    margin-bottom: 4px;
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .contact-section__side {
    display: grid;
    gap: 18px;
  }

  .contact-section__map {
    min-height: 320px;
    overflow: hidden;
    border: 1px solid var(--color-border-soft);
    border-radius: 22px;
    box-shadow: 0 14px 36px rgba(31, 26, 25, 0.06);
    background: var(--color-surface);
  }

  .contact-section__map iframe {
    display: block;
    width: 100%;
    max-width: 100%;
    height: 100%;
    min-height: 320px;
    border: 0;
  }

  .contact-section__actions {
    display: grid;
    gap: 12px;
  }

  @media (max-width: 980px) {
    .contact-section {
      padding: 64px 0 72px;
    }

    .contact-section__grid {
      grid-template-columns: 1fr;
    }

    .contact-section__content {
      max-width: none;
    }
  }

  @media (max-width: 640px) {
    .contact-section {
      padding: 56px 0;
    }

    .contact-section__info p {
      font-size: 0.96rem;
      line-height: 1.65;
    }

    .contact-section__map {
      min-height: 280px;
      border-radius: 18px;
    }

    .contact-section__map iframe {
      min-height: 280px;
    }
  }
</style>