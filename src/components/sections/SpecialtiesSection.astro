---
import SectionHeading from "../ui/SectionHeading.astro";
import SpecialtyCard from "../ui/cards/SpecialtyCard.astro";
---

<section class="specialties-section" id="especialidades">
  <div class="specialties-section__container">
    <div class="specialties-section__intro">
      <div class="specialties-section__content">
        <SectionHeading
          eyebrow="Especialidades"
          title="Tratamentos odontológicos com foco em reabilitação, estética e mais segurança para sorrir."
          text="Lucas Carvalho, especialista em implantodontia, é o profissional à frente da Carvalho Odontologia. Atua também na reabilitação oral e prótese, além de atendimentos clínicos e estéticos importantes para a saúde, manutenção e recuperação do sorriso."
          titleWidth="16ch"
          textWidth="60ch"
          class="specialties-section__heading"
        />

        
      </div>

      <div class="specialties-section__media">
        <img
          src="/image/lucas-no-consultorio.png"
    alt="Lucas Carvalho no consultório odontológico"
          class="specialties-section__image"
        />
        <div class="specialties-section__doctor">
          <strong class="specialties-section__doctor-name">Lucas Carvalho</strong>
          <span class="specialties-section__doctor-role">Cirurgião-dentista</span>
          <span class="specialties-section__doctor-role">CROSP 140332</span>
        </div>
      </div>
    </div>

    <div class="specialties-section__grid">
      <SpecialtyCard
        title="Implantodontia"
        text="Reposição dentária com foco em estabilidade, função mastigatória e mais segurança no dia a dia."
      />

      <SpecialtyCard
        title="Prótese dentária"
        text="Soluções planejadas para recuperar conforto, equilíbrio e naturalidade ao sorrir e falar."
      />

      <SpecialtyCard
        title="Dentística"
        text="Restaurações e procedimentos voltados à recuperação da estrutura, saúde e estética dos dentes."
      />

      <SpecialtyCard
        title="Limpeza e prevenção"
        text="Cuidados preventivos e acompanhamento clínico importante para manter a saúde bucal em dia."
      />

      <SpecialtyCard
        title="Facetas e estética"
        text="Tratamentos estéticos planejados para valorizar o sorriso com naturalidade e critério."
      />

      <SpecialtyCard
        title="Especialidades complementares"
        text="Quando necessário, o consultório conta com profissionais parceiros de outras especialidades, alinhados ao mesmo cuidado, respeito e responsabilidade."
      />
    </div>
  </div>
</section>

<style>
  .specialties-section {
    padding: 104px 0;
    background: var(--color-bg);
  }

  .specialties-section__container {
    width: min(var(--container-width), calc(100% - var(--container-padding)));
    margin: 0 auto;
  }

  .specialties-section__intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(420px, 580px);
    gap: 56px;
    align-items: start;
    margin-bottom: 46px;
  }

  .specialties-section__content {
    min-width: 0;
    padding-top: 8px;
  }

  .specialties-section__heading {
    margin-bottom: 28px;
  }

 .specialties-section__doctor {
  display: flex;
  flex-direction: column;
  gap: 2px;
  padding: 10px;
  align-items: flex-end;
  text-align: right;
}

  .specialties-section__doctor-name {
    font-size: 1.05rem;
    line-height: 1.3;
    font-weight: 700;
    color: var(--color-primary);
  }

  .specialties-section__doctor-role {
    font-size: 0.98rem;
    line-height: 1.4;
    color: var(--color-text-soft);
  }

  .specialties-section__media {
    width: 100%;
    min-width: 0;
  }

  .specialties-section__image {
    display: block;
    width: 100%;
    aspect-ratio: 1.36 / 1;
    object-fit: cover;
    border-radius: 28px;
    box-shadow: 0 16px 40px rgba(31, 26, 25, 0.08);
  }

  .specialties-section__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  @media (max-width: 1100px) {
    .specialties-section__intro {
      grid-template-columns: 1fr;
      gap: 28px;
      margin-bottom: 34px;
    }

    .specialties-section__content {
      padding-top: 0;
    }

    .specialties-section__media {
      max-width: 760px;
    }

    .specialties-section__image {
      aspect-ratio: 1.5 / 1;
    }
  }

  @media (max-width: 900px) {
    .specialties-section {
      padding: 80px 0;
    }

    .specialties-section__grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }
  }

  @media (max-width: 640px) {
    .specialties-section {
      padding: 64px 0;
    }

    .specialties-section__container {
      width: min(100% - 32px, var(--container-width));
    }

    .specialties-section__intro {
      gap: 22px;
      margin-bottom: 28px;
    }

    .specialties-section__heading {
      margin-bottom: 22px;
    }

    .specialties-section__doctor-name {
      font-size: 1rem;
    }

    .specialties-section__doctor-role {
      font-size: 0.94rem;
    }

    .specialties-section__image {
      border-radius: 20px;
    }

    .specialties-section__grid {
      gap: 16px;
    }
  }
</style>