---
import SectionHeading from "../ui/SectionHeading.astro";
import Button from "../ui/Button.astro";
---

<section class="clinic-section" id="consultorio">
  <div class="clinic-section__container">
    <div class="clinic-section__header">
      <SectionHeading
        eyebrow="O consultório"
        title="Um espaço pensado para atender com conforto, privacidade e tranquilidade."
        text="O consultório foi preparado para oferecer uma experiência mais prática e confortável, desde a chegada até o atendimento. Um ambiente pensado para quem valoriza organização, atenção aos detalhes e um cuidado mais próximo."
        align="center"
        titleWidth="22ch"
        textWidth="60ch"
      />

      <p class="clinic-section__plans">
        Atendimento particular e por convênios selecionados. Consulte pelo
        WhatsApp quais planos estão disponíveis no momento.
      </p>

      <div class="clinic-section__insurance">
        <p class="clinic-section__insurance-label">Convênios atendidos</p>

        <div class="clinic-section__insurance-logos">
          <img
            src="/image/logo-ideal-odonto.png"
            alt="Convênio Ideal Odonto"
            class="clinic-section__insurance-logo"
          />
          <img
            src="/image/logo-odontolife.png"
            alt="Convênio OdontoLife"
            class="clinic-section__insurance-logo"
          />
          <img
            src="/image/logo-uniodonto.png"
            alt="Convênio Uniodonto"
            class="clinic-section__insurance-logo"
          />
        </div>

        <p class="clinic-section__insurance-note">
          Consulte pelo WhatsApp a cobertura e os atendimentos disponíveis.
        </p>
      </div>

      <div class="clinic-section__actions">
        <Button
          href="https://wa.me/5515981708003"
          target="_blank"
          rel="noopener noreferrer"
        >
          Consultar planos pelo WhatsApp
        </Button>
      </div>
    </div>

    <div class="clinic-section__gallery">
      <img
        src="/image/consultorio1.png"
        alt="Recepção do consultório"
        class="clinic-section__image"
      />
      <img
        src="/image/consultorio2.png"
        alt="Ambiente interno do consultório"
        class="clinic-section__image"
      />
      <img
        src="/image/esterilizacao.png"
        alt="Sala de esterilização do consultório"
        class="clinic-section__image"
      />
      <img
        src="/image/fachada.png"
        alt="Fachada do consultório"
        class="clinic-section__image"
      />
    </div>
  </div>
</section>

<style>
  .clinic-section {
    padding: 72px 0 88px;
    background: #fcfaf7;
  }

  .clinic-section__container {
    width: min(var(--container-width), calc(100% - var(--container-padding)));
    margin: 0 auto;
  }

  .clinic-section__header {
    max-width: 820px;
    margin: 0 auto 32px;
    text-align: center;
  }

  .clinic-section__plans {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 12px;
    margin: -4px 0 0;
    font-size: 0.98rem;
    line-height: 1.7;
    color: #6f6460;
  }

  .clinic-section__insurance {
    margin: 20px 0 18px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .clinic-section__insurance-label {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .clinic-section__insurance-logos {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 10px;
  }

  .clinic-section__insurance-logo {
    display: block;
    width: auto;
    height: 96px;
    padding: 10px 14px;
    background: var(--color-surface);
    border: 1px solid rgba(31, 26, 25, 0.1);
    border-radius: 12px;
  }

  .clinic-section__insurance-note {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.45;
    color: rgba(31, 26, 25, 0.68);
    text-align: center;
  }

  .clinic-section__actions {
    margin-top: 18px;
    display: flex;
    justify-content: center;
  }

  .clinic-section__gallery {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  .clinic-section__image {
    display: block;
    width: 100%;
    height: 240px;
    object-fit: cover;
    border-radius: 18px;
  }

  @media (max-width: 980px) {
    .clinic-section {
      padding: 64px 0 72px;
    }

    .clinic-section__gallery {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .clinic-section__image {
      height: 220px;
    }
  }

  @media (max-width: 640px) {
    .clinic-section {
      padding: 56px 0;
    }

    .clinic-section__container {
      width: min(100% - 32px, var(--container-width));
    }

    .clinic-section__header {
      margin-bottom: 28px;
    }

    .clinic-section__plans {
      font-size: 0.95rem;
      line-height: 1.65;
    }

    .clinic-section__insurance-logo {
      height: 82px;
      padding: 8px 12px;
    }

    .clinic-section__gallery {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .clinic-section__image {
      height: 220px;
      border-radius: 16px;
    }
  }
</style>