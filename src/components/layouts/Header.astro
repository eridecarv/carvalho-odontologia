---
import Button from "../ui/Button.astro";

interface NavItem {
  label: string;
  href: string;
}

interface Props {
  logoHref?: string;
  logoSrc?: string;
  logoAlt?: string;
  ctaHref?: string;
  ctaLabel?: string;
  navItems?: NavItem[];
}

const defaultNavItems: NavItem[] = [
  { label: "Sobre", href: "#sobre" },
  { label: "Especialidades", href: "#especialidades" },
  { label: "Consultório", href: "#consultorio" },
  { label: "Depoimentos", href: "#depoimentos" },
  { label: "Contato", href: "#contato" },
];

const {
  logoHref = "/",
  logoSrc = "/logos/logo-red-transparente.webp",
  logoAlt = "Logo Carvalho Odontologia",
  ctaHref = "https://wa.me/5515981708003",
  ctaLabel = "WhatsApp",
  navItems = defaultNavItems,
} = Astro.props;
---

<header class="site-header">
  <div class="container">
    <div class="site-header__inner">
      <a
        href={logoHref}
        class="site-header__logo-link"
        aria-label="Carvalho Odontologia"
      >
        <img
          src={logoSrc}
          alt={logoAlt}
          class="site-header__logo"
          width="150"
          height="72"
        />
      </a>

      <nav class="site-header__nav" aria-label="Navegação principal">
        {
          navItems.map((item) => (
            <a href={item.href} class="site-header__nav-link">
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="site-header__cta">
        <Button
          href={ctaHref}
          target="_blank"
          rel="noopener noreferrer"
          variant="primary"
        >
          {ctaLabel}
        </Button>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    width: 100%;
    background: var(--color-surface);
    border-bottom: 1px solid rgba(31, 26, 25, 0.08);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    min-height: 108px;
  }

  .site-header__logo-link {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    text-decoration: none;
  }

  .site-header__logo {
    display: block;
    width: 150px;
    height: auto;
  }

  .site-header__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    gap: 28px;
    min-width: 0;
  }

  .site-header__nav-link {
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.98rem;
    font-weight: 500;
    line-height: 1;
    transition:
      color 0.2s ease,
      opacity 0.2s ease;
  }

  .site-header__nav-link:hover {
    color: var(--color-primary);
    opacity: 0.9;
  }

  .site-header__cta {
    flex-shrink: 0;
  }

  @media (max-width: 980px) {
    .site-header__inner {
      min-height: 92px;
      gap: 20px;
    }

    .site-header__nav {
      gap: 18px;
    }

    .site-header__nav-link {
      font-size: 0.94rem;
    }

    .site-header__logo {
      width: 132px;
    }
  }

  @media (max-width: 768px) {
    .site-header__inner {
      min-height: 84px;
    }

    .site-header__nav {
      display: none;
    }

    .site-header__logo {
      width: 124px;
    }
  }

  @media (max-width: 640px) {
    .site-header__inner {
      gap: 14px;
    }

    .site-header__logo {
      width: 116px;
    }
  }
</style>