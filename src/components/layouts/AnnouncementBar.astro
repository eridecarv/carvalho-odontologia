---
interface Props {
  text?: string;
}

const {
  text = "Atendimento odontológico no Éden, em Sorocaba.",
} = Astro.props;
---

<section class="announcement-bar" aria-label="Informação institucional">
  <div class="container">
    <p class="announcement-bar__text">{text}</p>
  </div>
</section>

<style>
  .announcement-bar {
    width: 100%;
    background: linear-gradient(
      90deg,
      var(--color-primary) 0%,
      var(--color-accent) 100%
    );
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
  }

  .announcement-bar__text {
    margin: 0;
    padding: 13px 0;
    font-size: 0.92rem;
    line-height: 1.4;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: var(--color-surface);
    text-align: center;
  }

  @media (max-width: 640px) {
    .announcement-bar__text {
      padding: 11px 0;
      font-size: 0.84rem;
    }
  }
</style>